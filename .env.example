# =============================================================================
# SAHJONY Platform - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to version control!

# =============================================================================
# AI PROVIDERS - Required for Agent Brain
# =============================================================================

# Anthropic API Key (for Claude AI)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Anthropic Model (optional, defaults to claude-3-5-sonnet-20241022)
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# OpenAI API Key (for GPT-4)
OPENAI_API_KEY=sk-xxxxx

# OpenAI Model (optional, defaults to gpt-4-turbo)
# OPENAI_MODEL=gpt-4-turbo

# =============================================================================
# WEB SEARCH - Google Custom Search API
# =============================================================================
# Get your API key from: https://console.cloud.google.com/
# Enable "Custom Search API" and create credentials
# Free tier: 100 queries/day
GOOGLE_SEARCH_API_KEY=your-google-search-api-key
GOOGLE_SEARCH_ENGINE_ID=your-search-engine-id

# =============================================================================
# TAVILY - AI-Optimized Search (Alternative to Google)
# =============================================================================
# Free tier available at https://tavily.com
# TAVILY_API_KEY=your-tavily-api-key

# =============================================================================
# CODE EXECUTION - Piston API (Free, Open Source)
# =============================================================================
# Piston is a free code execution engine
# Self-host or use public instance
# PISTON_API_URL=https://emkc.org/api/v2/piston

# =============================================================================
# FREEBUFF INTEGRATION - AI Coding Agent
# =============================================================================
# Freebuff is the free coding agent from CodebuffAI
# If running Freebuff locally, set the API URL
# FREEBUFF_API_URL=http://localhost:3001

# =============================================================================
# HERMES BRIDGE - Connect to Hermes Agent Microservice
# =============================================================================
# If running Hermes Agent as a separate Python service, configure connection
# HERMES_AGENT_URL=http://localhost:8000
# HERMES_AGENT_API_KEY=your-hermes-api-key

# =============================================================================
# DATABASE - PostgreSQL via Prisma
# =============================================================================
# Example: postgresql://user:password@localhost:5432/sahjony_db
DATABASE_URL=postgresql://user:password@localhost:5432/sahjony_db

# =============================================================================
# NEXTAUTH - Authentication
# =============================================================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secret-key-min-32-chars-long

# =============================================================================
# SUPABASE - Database & Auth (if using Supabase)
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# =============================================================================
# APPLICATION INFO
# =============================================================================
# Optional: Custom branding
# APP_NAME=SAHJONY
# APP_URL=https://sahjony.com