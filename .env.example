# ── Alpaca Broker API ──
# Standard Alpaca SDK variable names (preferred):
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=
# Read-only equity history used by the analysis brain (never order APIs):
HISTORICAL_DATA_PROVIDER=alpaca
HISTORICAL_LOOKBACK_DAYS=365
HISTORICAL_MIN_BARS=200
HISTORICAL_MAX_STALENESS_HOURS=72

# ── Robinhood Agentic MCP (read-only) ──
# Optional finite client budgets. Gateway retries remain bounded inside the gateway.
ROBINHOOD_MCP_HEALTH_TIMEOUT_SECONDS=90
ROBINHOOD_MCP_ACCOUNT_TIMEOUT_SECONDS=90
ROBINHOOD_MCP_POSITIONS_TIMEOUT_SECONDS=285
ROBINHOOD_MCP_QUOTE_TIMEOUT_SECONDS=285
# Sandbox:    https://broker-api.sandbox.alpaca.markets
# Production: https://broker-api.alpaca.markets
APCA_API_BASE_URL=https://broker-api.sandbox.alpaca.markets
# Account to trade on (auto-resolved from first account if omitted):
ALPACA_ACCOUNT_ID=
# Legacy aliases (also accepted as fallbacks):
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# ── Robinhood Crypto Trading API ──
# Never commit real credentials. The API key and Ed25519 private key must be a
# matching pair created in the Robinhood account that is authorized for API use.
BROKER=robinhood
ROBINHOOD_API_KEY=
ROBINHOOD_PRIVATE_KEY=
# Operator-approved API account identifier returned by Robinhood. Leave blank
# until Robinhood confirms that it maps to the intended funded crypto account.
ROBINHOOD_APPROVED_API_ACCOUNT=
# Keep both live locks disabled until tools/account_readiness.py reports ready.
ROBINHOOD_LIVE=false
LIVE_TRADING_ACK=
TICKERS=BTC/USD,ETH/USD,XRP/USD

# ── Custom variables ──
# Conservative research execution costs (simulation only)
SIM_SLIPPAGE_BPS=5
SIM_COMMISSION_PER_SHARE=0.005
SIM_OPTION_FEE_PER_CONTRACT=0.65

# Add any additional environment variables you need for your own integrations here.
