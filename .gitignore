# secrets & local env — NEVER commit
.env
.env.*
!.env.template
# per-desk env files (scripts/desk.sh) hold real keys — only *.env.example is committed
desks/*.env
desks/homes/
# keep committed templates/examples (they hold NO secrets, only blank keys)
!.env.example
!**/.env.example
!**/.env.template

# runtime state, database, logs
state.json
data/
logs/
*.log
*.db
*.db-wal
*.db-shm

# python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/

# os / editor
.DS_Store
.vscode/
.idea/

# per-investor read-only snapshots carry names + stakes — generated at deploy time, never committed
public/investors/
public/promotion_producers.json

# NOTE: public/status.json IS committed — it is the dashboard's (secret-free) data snapshot.

# Operator kill switch (local only)
HALT

# Node (dashboard UI test deps)
node_modules/
package-lock.json
package.json
.vercel
.env.local
.env*

# Local agent/test scratch data and broker private key material
.tmp/
robinhood_keypair*.txt
