{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "echo 'SAHJONY CAPITAL LLC — static owner dashboard, no build'",
  "outputDirectory": "public",
  "cleanUrls": true,
  "git": {
    "deploymentEnabled": {
      "master": false
    }
  },
  "headers": [
    { "source": "/status.json", "headers": [{ "key": "Cache-Control", "value": "no-store, max-age=0" }] },
    { "source": "/robinhood.json", "headers": [{ "key": "Cache-Control", "value": "no-store, max-age=0" }] },
    { "source": "/api/promotion-status", "headers": [{ "key": "Cache-Control", "value": "no-store, max-age=0" }] },
    { "source": "/", "headers": [{ "key": "Cache-Control", "value": "no-cache" }] }
  ]
}
