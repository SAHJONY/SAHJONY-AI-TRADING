# SAHJONY multi-tenant worker — environment
# Run: python -m worker.run   (on a cron schedule, on a worker host)

# Service-role Postgres connection to your Supabase project (bypasses RLS so the
# worker can read every active desk). Find it in Supabase → Project Settings → Database.
SUPABASE_DB_URL=

# AES-256-GCM key shared with the Next.js web app (used to decrypt customer keys).
# Generate: python -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())"
SECRET_ENCRYPTION_KEY=

# Single-owner fallback: if your desk has no stored (encrypted) credentials, the
# worker uses these host keys instead — the easiest way to run the live dashboard
# for yourself without the key-entry UI. Paper keys; live still needs the opt-in.
WORKER_ALPACA_API_KEY=
WORKER_ALPACA_SECRET_KEY=
WORKER_ANTHROPIC_API_KEY=

LOG_LEVEL=INFO
