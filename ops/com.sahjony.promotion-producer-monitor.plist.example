<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>com.sahjony.promotion-producer-monitor</string>
  <key>WorkingDirectory</key><string>/Users/REPLACE_ME/SAHJONY-AI-TRADING</string>
  <key>ProgramArguments</key>
  <array>
    <string>/Users/REPLACE_ME/SAHJONY-AI-TRADING/.venv/bin/python</string>
    <string>scripts/monitor_promotion_producers.py</string>
    <string>--fail-on-critical</string>
  </array>
  <key>StartInterval</key><integer>300</integer>
  <key>RunAtLoad</key><true/>
  <key>StandardOutPath</key><string>/Users/REPLACE_ME/SAHJONY-AI-TRADING/logs/promotion-monitor.out.log</string>
  <key>StandardErrorPath</key><string>/Users/REPLACE_ME/SAHJONY-AI-TRADING/logs/promotion-monitor.err.log</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PROMOTION_MAX_PENDING</key><string>25</string>
    <key>PROMOTION_MAX_FRESHNESS_SECONDS</key><string>3600</string>
    <key>PROMOTION_MAX_DELIVERY_LAG_SECONDS</key><string>3600</string>
  </dict>
</dict>
</plist>
