# ─────────────────────────────────────────────────────────────────────────────
# SAHJONY CAPITAL LLC — environment template
#   cp .env.template .env   (NEVER commit the real .env — see .gitignore)
# With NO keys set, the desk runs OFFLINE-SIM: synthetic data, ZERO real orders.
# Add keys to go live on Alpaca PAPER + enable the AI brain + voice comms.
# The owner dashboard's Environment page can generate this file for you.
# ─────────────────────────────────────────────────────────────────────────────

# --- Broker (Alpaca) ---------------------------------------------------------
# Which venue to trade. 'alpaca' (US equities/options + crypto) is the only one
# wired today; add more via utils/broker.py (see utils/brokers/template_adapter.py).
BROKER=alpaca
# Leave keys blank for OFFLINE-SIM. With keys + ALPACA_PAPER=true → paper account.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true

# --- Interactive Brokers (only when BROKER=ibkr) -----------------------------
# Requires a running TWS / IB Gateway (pip install -r requirements-ibkr.txt).
# Ports: paper TWS 7497 / Gateway 4002 ; live TWS 7496 / Gateway 4001.
# Symbols: AAPL | LSE:VOD:GBP | FX:EUR/USD | CRYPTO:BTC/USD | FUT:ES@CME
# For FX/futures/non-US set MARKET_HOURS=24_7 so the desk runs continuously.
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1
IBKR_ACCOUNT=

# --- CCXT crypto exchanges (only when BROKER=ccxt) ---------------------------
# Worldwide crypto via ~100 exchanges (pip install -r requirements-ccxt.txt).
# Symbols use unified form: BTC/USDT, ETH/USD. CCXT_SANDBOX=true uses testnet.
CCXT_EXCHANGE=binance
CCXT_API_KEY=
CCXT_SECRET=
CCXT_PASSWORD=
CCXT_SANDBOX=true
CCXT_QUOTE=USDT

# --- LIVE REAL-MONEY trading (deliberate opt-in) -----------------------------
# To trade real money you must do BOTH: set ALPACA_PAPER=false above AND set the
# acknowledgement below to exactly this phrase. Anything else keeps live refused.
# Hard risk ceilings in config.py still apply and cannot be widened from here.
LIVE_TRADING_ACK=

# --- Universe ----------------------------------------------------------------
# US equities: AAPL,MSFT,SPY  |  Crypto (24/7/365): BTC/USD,ETH/USD,SOL/USD
# Crypto pairs (with a '/') auto-enable 24/7 trading and route to the ladder
# (options/wheel are equities-only). Don't mix asset classes in one desk —
# run a separate isolated desk per class via SAHJONY_HOME (below).
TICKERS=AAPL,MSFT,SPY
BENCHMARK=SPY
# Market hours: 'us' (cash session) or '24_7' (always open). Auto = 24_7 when
# every ticker is crypto; set explicitly to force a 24/7 cadence.
MARKET_HOURS=us

# --- Multi-account isolation -------------------------------------------------
# Give each account its own home dir so state/db/status/HALT never collide.
# Leave blank for the default (repo root). One desk per account:
#   SAHJONY_HOME=~/desks/us-equities   python main.py --loop
#   SAHJONY_HOME=~/desks/crypto-247    python main.py --loop
SAHJONY_HOME=

# --- AI brain (PRIMARY engine: Claude) + counsellors -------------------------
# Counsellors (advisory only): OpenAI (GPT), Grok (xAI), Gemini (Google).
# AUTO_UPDATE_MODELS=true (default) makes each engine autonomously run its newest
# model (latest Fable for Claude, latest flagship GPT/Grok/Gemini), refreshed ~daily;
# the *_MODEL values below are only fallbacks used when that lookup can't run.
# Fable 5 is Anthropic's most capable line; it needs a funded Anthropic account +
# 30-day data retention. Until Anthropic is funded the brain auto-falls back to the
# free NVIDIA NIM engine below, so the desk keeps running.
AI_BRAIN_ENABLED=false
AUTO_UPDATE_MODELS=true
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-fable-5
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
XAI_API_KEY=
XAI_MODEL=grok-2-latest
# Gemini accepts GEMINI_API_KEY (or GOOGLE_API_KEY).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
# NVIDIA NIM — FREE, OpenAI-compatible. Acts as a counsellor AND the last-resort
# fallback brain (used automatically if Claude is absent or fails). Get a free key
# at build.nvidia.com. Pick any catalog model via NVIDIA_MODEL.
NVIDIA_API_KEY=
NVIDIA_MODEL=openai/gpt-oss-120b
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# --- Alt-data overlay (QuiverQuant insider + congressional trading) ----------
# A fault-isolated ADVISORY signal: recent insider/congress disclosures per symbol
# become a small conviction tilt in [-0.15,0.15]. Auto-on when a key is present.
# The desk runs on GitHub Actions (not Vercel) — set QUIVER_API_KEY as a GitHub
# Actions secret (or here in .env for local runs). Off with no key.
QUIVER_API_KEY=
QUIVER_ENABLED=true
QUIVER_BASE_URL=https://api.quiverquant.com/beta

# --- Advisory Board (6-agent Intelligence Council; default ON) ----------------
# Buffett (quality/value), Munger (discipline), Macro, Growth, Quant + a Risk
# Agent protection gate; a Decision Engine blends them into a bounded conviction
# tilt (±0.10, gate-scaled). Advisory only — execution stays under the hard risk
# rules. Transparent price-based proxies, not the namesakes' actual models.
ADVISORS_ENABLED=true

# --- Hermes guardian (background agent; default ON) --------------------------
# Runs before the strategists every cycle: validates every market feed (bad feeds
# are quarantined — no NEW risk, exits still flow), keeps an honest Sharpe/Sortino
# scorecard, and self-improves in perpetuity: the council's realized hit-rate
# becomes a small bounded conviction tilt (±0.10) and each strategy desk's realized
# win-rate re-weights its capital (×0.70–×1.15 — trimmed, never switched off).
# Memory persists in state.json with exponential decay. Transparent — no black box.
HERMES_ENABLED=true
# The desk's well-defined objective, shown on the dashboard and reports.
HERMES_GOAL=Maximize risk-adjusted return (Sharpe) within the hard risk ceilings — capital preservation first, paper trading only.

# --- Copy trading (mirror an external disclosure / signal feed) --------------
# Off by default. Point at a JSON feed of [{"symbol","side","weight"?}] (e.g. a
# congressional-disclosure aggregator). Mirrored trades still pass the Risk
# Officer (caps, hard ceilings) + Execution Trader. Key lives here only.
COPY_TRADING_ENABLED=false
COPY_TRADING_SOURCE_URL=
COPY_TRADING_API_KEY=
COPY_TRADING_MAX_SYMBOLS=10

# --- Day trading / Forex (intraday desk; never holds overnight) --------------
# A momentum + mean-reversion desk that trades the FX majors (and any extra
# intraday symbols). FX prices come from the simulator/IBKR natively; on a broker
# without forex (e.g. Alpaca) those orders fail-safe. Risk Officer still gates size.
DAY_TRADING_ENABLED=true
FOREX_PAIRS=EUR/USD,GBP/USD,USD/JPY,AUD/USD
DAY_TRADE_SYMBOLS=
DAY_TRADE_TARGET_PCT=0.015
DAY_TRADE_STOP_PCT=0.01
DAY_TRADE_MAX_UNITS=100
DAY_TRADE_MIN_SIGNAL=0.55

# --- Voice comms (Bland.ai) --------------------------------------------------
VOICE_ALERTS=false
VOICE_API_KEY=
VOICE_FROM_NUMBER=
OWNER_PHONE=
VOICE_LANGUAGE=en
VOICE_NAME=june

# --- Risk (hard ceilings live in config.py; .env can only tighten) -----------
MAX_ALLOCATION_PCT=0.10
MAX_TOTAL_DEPLOYED_PCT=0.60
MIN_COUNCIL_CONVICTION=0.55
# Daily-loss circuit breaker: halt NEW risk for the rest of the day once equity
# falls this far below the day's open (exits still flow). Clamped to <= 0.25.
MAX_DAILY_DRAWDOWN_PCT=0.06
# Kill switch: set true (or `touch HALT` in the repo root) to suspend all new
# risk immediately — no code change, no key change. Exits still allowed.
TRADING_HALT=false
# Volatility targeting: when realized portfolio vol (annualized, off the equity
# curve) runs above this, new-position budgets scale down proportionally
# (floor ×0.5; never levers up). 0 disables. Hard ceilings still apply on top.
VOL_TARGET_ANNUAL=0.20

# --- Wheel strategy ----------------------------------------------------------
WHEEL_PUT_OTM_PCT=0.10
WHEEL_CALL_OTM_PCT=0.10
WHEEL_DTE_MIN=14
WHEEL_DTE_MAX=28

# --- Credit spreads (defined-risk options desk) -------------------------------
# Bull put spreads: sell an OTM put, buy a further-OTM hedge put. Max loss is
# capped at (width − credit) and known to the dollar BEFORE entry — the Risk
# Officer gates on exactly that number. Far more capital-efficient than
# cash-secured puts. Equities only (no crypto options).
CREDIT_SPREADS_ENABLED=true
SPREAD_SHORT_OTM_PCT=0.05
SPREAD_WIDTH_PCT=0.05

# --- Trailing-ladder strategy ------------------------------------------------
LADDER_HARD_FLOOR_PCT=0.10
LADDER_RATCHET_TRIGGER_PCT=0.10
LADDER_TRAIL_PCT=0.05
LADDER_BASE_QTY=10
LADDER_ENABLE_AVERAGING=true
LADDER_CATASTROPHIC_PCT=0.40

# --- Ops ---------------------------------------------------------------------
CYCLE_MINUTES=15
LOG_LEVEL=INFO
