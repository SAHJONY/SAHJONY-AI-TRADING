# Desk: Robinhood crypto (24/7) — copy to desks/robinhood-crypto.env and add keys.
# The filled-in copy is gitignored; this example holds NO secrets.
#
# READ vs WRITE: just the keys give READ-ONLY live data (mode "live-data" — real
# balances on the dashboard, zero orders). Real orders additionally require the
# double-lock at the bottom. See GO_LIVE.md §E.

BROKER=robinhood
ROBINHOOD_API_KEY=
ROBINHOOD_PRIVATE_KEY=
ROBINHOOD_QUOTE=USD

TICKERS=BTC/USD,ETH/USD
MARKET_HOURS=24_7
CYCLE_MINUTES=15
FIRM_NAME="SAHJONY CAPITAL LLC — CRYPTO"

# Start tiny. Hard ceilings in config.py still apply and cannot be widened.
MAX_ALLOCATION_PCT=0.02
MAX_TOTAL_DEPLOYED_PCT=0.20
MAX_DAILY_DRAWDOWN_PCT=0.03

# ── REAL MONEY double-lock (leave OFF until you deliberately arm) ──
ROBINHOOD_LIVE=false
LIVE_TRADING_ACK=
