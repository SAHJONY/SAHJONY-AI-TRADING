# Desk: Alpaca US equities (PAPER) — copy to desks/alpaca-equities.env, add keys.
# The filled-in copy is gitignored; this example holds NO secrets.
#
# This is the autonomous EQUITIES desk: Robinhood has no official brokerage
# trading API, so equities trade on Alpaca — paper first, always. Your Robinhood
# brokerage accounts stay monitor-only on the dashboard (accounts.yaml).

BROKER=alpaca
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true            # keep true — paper account, zero real dollars

TICKERS=AAPL,MSFT,NVDA,SPY,QQQ
BENCHMARK=SPY
MARKET_HOURS=us
CYCLE_MINUTES=15
FIRM_NAME="SAHJONY CAPITAL LLC — EQUITIES"

MAX_ALLOCATION_PCT=0.10
MAX_TOTAL_DEPLOYED_PCT=0.60
MAX_DAILY_DRAWDOWN_PCT=0.06

# Going LIVE on Alpaca later requires the deliberate opt-in (GO_LIVE.md §D):
# ALPACA_PAPER=false AND LIVE_TRADING_ACK=I_UNDERSTAND_REAL_MONEY
LIVE_TRADING_ACK=
