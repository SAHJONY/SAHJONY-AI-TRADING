# Robinhood Agentic Trading MCP desk
# Copy the values you need into .env. Never commit secrets.

BROKER=robinhood_mcp
TICKERS=VTI,QQQ,NVDA,MSFT
BENCHMARK=SPY
MARKET_HOURS=us

# Local authenticated MCP gateway. The gateway must connect to the official
# Robinhood Trading MCP and expose the contract documented in
# utils/brokers/robinhood_mcp.py.
ROBINHOOD_MCP_GATEWAY_URL=http://127.0.0.1:8787
ROBINHOOD_MCP_GATEWAY_TOKEN=
ROBINHOOD_MCP_EXPECTED_LAST4=1131

# Keep disabled until read-only identity, balances, positions, quotes, preview,
# cancellation, and reconciliation checks all pass.
ROBINHOOD_MCP_LIVE=false
LIVE_TRADING_ACK=

# Conservative launch limits.
TRADING_CAPITAL=25
MAX_ALLOCATION_PCT=0.02
MAX_TOTAL_DEPLOYED_PCT=0.10
MAX_DAILY_DRAWDOWN_PCT=0.02
MIN_COUNCIL_CONVICTION=0.65
TRADING_HALT=false
